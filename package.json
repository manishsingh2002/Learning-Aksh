{
  "name": "examprep-api",
  "version": "1.0.0",
  "description": "Indian Exam Prep Platform — REST API",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start":       "node src/server.js",
    "dev":         "nodemon src/server.js",
    "dev:debug":   "MONGOOSE_DEBUG=true nodemon src/server.js",
    "lint":        "eslint . --ext .js",
    "lint:fix":    "eslint . --ext .js --fix",
    "test":        "NODE_ENV=test jest --forceExit --detectOpenHandles",
    "test:watch":  "NODE_ENV=test jest --watch",
    "test:cover":  "NODE_ENV=test jest --coverage --forceExit",
    "seed":        "node scripts/seed.js",
    "seed:master": "node scripts/seedMasterData.js"
  },
  "dependencies": {
    "axios":                      "^1.7.2",
    "bcryptjs":                   "^2.4.3",
    "cloudinary":                 "^2.3.1",
    "compression":                "^1.7.4",
    "cookie-parser":              "^1.4.6",
    "cors":                       "^2.8.5",
    "dotenv":                     "^16.4.5",
    "express":                    "^4.19.2",
    "express-mongo-sanitize":     "^2.2.0",
    "express-rate-limit":         "^7.3.1",
    "helmet":                     "^7.1.0",
    "hpp":                        "^0.2.3",
    "ioredis":                    "^5.4.1",
    "joi":                        "^17.13.1",
    "jsonwebtoken":               "^9.0.2",
    "mongoose":                   "^8.5.1",
    "morgan":                     "^1.10.0",
    "multer":                     "^1.4.5-lts.1",
    "multer-storage-cloudinary":  "^4.0.0",
    "nanoid":                     "^3.3.7",
    "node-cron":                  "^3.0.3",
    "nodemailer":                 "^6.9.14",
    "rate-limit-redis":           "^4.2.0",
    "razorpay":                   "^2.9.2",
    "socket.io":                  "^4.7.5",
    "twilio":                     "^5.2.3",
    "winston":                    "^3.13.0",
    "winston-daily-rotate-file":  "^5.0.0",
    "xss-clean":                  "^0.1.4"
  },
  "devDependencies": {
    "eslint":          "^8.57.0",
    "jest":            "^29.7.0",
    "nodemon":         "^3.1.4",
    "supertest":       "^7.0.0"
  },
  "nodemonConfig": {
    "watch":  ["server.js", "app.js", "routes/", "controllers/", "models/", "middleware/", "utils/", "config/"],
    "ext":    "js,json",
    "ignore": ["logs/", "node_modules/", "*.test.js"],
    "delay":  "1000"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":       ["**/__tests__/**/*.js", "**/*.test.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["controllers/**/*.js", "utils/**/*.js", "middleware/**/*.js"]
  }
}
